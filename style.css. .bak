/* 1. إعدادات عامة للموقع لضمان ظهور الخطوط بشكل احترافي */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

/* 2. تنسيق خلفية الموقع (أسود فخم مع تدرج) */
body {
    background: radial-gradient(circle, #1a1a1a 0%, #000000 100%);
    color: #f1f1f1;
    line-height: 1.6;
    overflow-x: hidden;
}

/* 3. شريط التنقل (Navigation Bar) */
nav {
    background: rgba(0, 0, 0, 0.8);
    padding: 20px;
    position: sticky;
    top: 0;
    z-index: 1000;
    border-bottom: 2px solid #d4af37; /* خط ذهبي */
}

nav ul {
    display: flex;
    justify-content: center;
    list-style: none;
}

nav ul li {
    margin: 0 20px;
}

nav ul li a {
    color: #d4af37;
    text-decoration: none;
    font-weight: bold;
    text-transform: uppercase;
    transition: 0.5s;
}

nav ul li a:hover {
    color: #fff;
    text-shadow: 0 0 10px #d4af37;
}

/* 4. تنسيق العناوين (Headers) */
h1, h2 {
    color: #d4af37;
    text-align: center;
    margin-bottom: 20px;
    letter-spacing: 2px;
}

/* 5. تصميم البطاقات (Cards) للأقسام والمهندسين */
.engineer-card {
    background: #262626;
    border: 1px solid #333;
    padding: 20px;
    margin: 20px auto;
    width: 80%;
    border-radius: 10px;
    transition: transform 0.3s;
}

.engineer-card:hover {
    transform: translateY(-10px);
    border-color: #d4af37;
}

/* 6. الأزرار (Buttons) */
.btn {
    display: inline-block;
    padding: 10px 25px;
    background: #d4af37;
    color: #000;
    border-radius: 5px;
    text-decoration: none;
    font-weight: bold;
    margin-top: 15px;
}
/* تنسيقات صفحة المطور */
.developer-container {
    max-width: 1000px;
    margin: 50px auto;
    padding: 20px;
}

.dev-avatar {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    border: 5px solid #d4af37;
    margin-bottom: 20px;
    box-shadow: 0 0 20px rgba(212, 175, 55, 0.5);
}

.skills-section {
    margin-top: 50px;
    background: rgba(255, 255, 255, 0.05);
    padding: 30px;
    border-radius: 15px;
}

.skill-card {
    margin-bottom: 20px;
    text-align: left;
}

.progress-bar {
    background: #333;
    height: 10px;
    border-radius: 5px;
    margin-top: 10px;
}

.progress {
    background: #d4af37;
    height: 100%;
    border-radius: 5px;
    box-shadow: 0 0 10px #d4af37;
}

.projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 40px;
}

.project-item {
    background: #111;
    border-left: 4px solid #d4af37;
    padding: 20px;
    border-radius: 5px;
    transition: 0.3s;
}

.project-item:hover {
    background: #1a1a1a;
    transform: translateX(10px);
}
